#!/usr/bin/env bash

set -euo pipefail

exec 2>&1

dpkg_cfg_marker_begin="# BEGIN libjson-safe staged dpkg root"
dpkg_cfg_marker_end="# END libjson-safe staged dpkg root"

script_dir="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
if [[ -d "${script_dir}/../../tests/package" ]]; then
    safe_root="$(CDPATH= cd -- "${script_dir}/../.." && pwd)"
elif [[ -d "${script_dir}/../../safe/tests/package" ]]; then
    safe_root="$(CDPATH= cd -- "${script_dir}/../../safe" && pwd)"
else
    echo "could not locate safe/tests/package from ${script_dir}" >&2
    exit 1
fi

smoke_dir="${safe_root}/tests/package"
tmpdir="$(mktemp -d)"
trap 'rm -rf "${tmpdir}"' EXIT

detect_multiarch() {
    local triplet=""

    triplet="$(cc -print-multiarch 2>/dev/null || true)"
    if [[ -n "${triplet}" ]]; then
        printf '%s\n' "${triplet}"
        return 0
    fi

    if command -v dpkg-architecture >/dev/null 2>&1; then
        dpkg-architecture -qDEB_HOST_MULTIARCH
        return 0
    fi

    echo "could not determine Debian multiarch triplet" >&2
    return 1
}

multiarch="$(detect_multiarch)"
json_c_cmake_dir=""
staged_root=""

if [[ -f "${HOME}/.dpkg.cfg" ]]; then
    staged_root="$(awk \
        -v begin="${dpkg_cfg_marker_begin}" \
        -v end="${dpkg_cfg_marker_end}" \
        '
            $0 == begin { in_block = 1; next }
            $0 == end { in_block = 0; next }
            in_block && /^root=/ { print substr($0, 6) }
        ' \
        "${HOME}/.dpkg.cfg" | tail -n 1)"
fi

if [[ -n "${staged_root}" && -f "${staged_root}/usr/lib/${multiarch}/pkgconfig/json-c.pc" ]]; then
    export PKG_CONFIG_SYSROOT_DIR="${staged_root}"
    export PKG_CONFIG_LIBDIR="${staged_root}/usr/lib/${multiarch}/pkgconfig:${staged_root}/usr/share/pkgconfig"
    export LD_LIBRARY_PATH="${staged_root}/usr/lib/${multiarch}${LD_LIBRARY_PATH+:${LD_LIBRARY_PATH}}"
    json_c_cmake_dir="${staged_root}/usr/lib/${multiarch}/cmake/json-c"
    echo "using staged non-root dpkg root: ${staged_root}"
else
    json_c_cmake_dir="$(pkg-config --variable=libdir json-c)/cmake/json-c"
fi

echo "shared smoke: pkg-config --cflags --libs json-c"
cc \
    $(pkg-config --cflags json-c) \
    "${smoke_dir}/pkgconfig_shared_smoke.c" \
    $(pkg-config --libs json-c) \
    -o "${tmpdir}/pkgconfig_shared_smoke"
"${tmpdir}/pkgconfig_shared_smoke"

echo "static smoke: pkg-config --static --libs json-c"
read -r -a static_tokens <<<"$(pkg-config --static --libs json-c)"
static_args=()
for token in "${static_tokens[@]}"; do
    if [[ "${token}" == "-ljson-c" ]]; then
        static_args+=("-Wl,-Bstatic" "${token}" "-Wl,-Bdynamic")
    else
        static_args+=("${token}")
    fi
done
cc \
    $(pkg-config --cflags json-c) \
    "${smoke_dir}/pkgconfig_static_smoke.c" \
    "${static_args[@]}" \
    -o "${tmpdir}/pkgconfig_static_smoke"
"${tmpdir}/pkgconfig_static_smoke"

echo "cmake shared smoke: find_package(json-c CONFIG)"
cmake \
    -S "${smoke_dir}/cmake-smoke" \
    -B "${tmpdir}/cmake-smoke" \
    -Djson-c_DIR="${json_c_cmake_dir}"
cmake --build "${tmpdir}/cmake-smoke"
"${tmpdir}/cmake-smoke/cmake_smoke"

echo "cmake static smoke: json-c::json-c-static"
"${tmpdir}/cmake-smoke/cmake_static_smoke"
