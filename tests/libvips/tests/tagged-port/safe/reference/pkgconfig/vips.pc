prefix=/home/yans/code/safelibs/ported/libvips/build-check-install
includedir=${prefix}/include
libdir=${prefix}/lib

Name: vips
Description: Image processing library
Version: 8.15.1
Requires: glib-2.0 >= 2.52, gio-2.0, gobject-2.0
Requires.private: gmodule-no-export-2.0, expat, zlib >= 0.4, libjpeg, libpng >= 1.2.9, libwebp >= 0.6, libwebpmux >= 0.6, libwebpdemux >= 0.6, pangocairo >= 1.32.6, pangoft2 >= 1.32.6, fontconfig, libtiff-4
Libs: -L${libdir} -lvips
Libs.private: -pthread -lm
Cflags: -I${includedir}
