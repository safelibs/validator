#!/usr/bin/make -f

export DEB_BUILD_MAINT_OPTIONS = hardening=+bindnow
export CARGO_TERM_COLOR = never
export RUSTFLAGS = -C link-arg=-Wl,-z,relro -C link-arg=-Wl,-z,now

REPO_ROOT := $(CURDIR)/..
XTASK := cargo run --manifest-path $(REPO_ROOT)/safe/Cargo.toml -p xtask --
STALE_CLEAN_PATHS := debian/.debhelper debian/tmp debian/libsdl2-2.0-0 debian/libsdl2-dev debian/libsdl2-tests

.PHONY: clean

clean:
	@set -eu; \
	for path in $(STALE_CLEAN_PATHS); do \
		if [ -e "$$path" ] && [ ! -w "$$path" ]; then \
			stale_path="$$path.stale.$$$$"; \
			echo "debian/rules: moving stale packaging state $$path to $$stale_path"; \
			mv "$$path" "$$stale_path"; \
		fi; \
	done
	dh clean --buildsystem=none

%:
	dh $@ --buildsystem=none

override_dh_auto_configure:

override_dh_auto_build:
	cd $(REPO_ROOT) && cargo build --manifest-path safe/Cargo.toml -p safe-sdl -p safe-sdl2-test -p safe-sdl2main --release

override_dh_auto_test:

override_dh_auto_install:
	cd $(REPO_ROOT) && $(XTASK) stage-install --generated safe/generated --original original --root safe/debian/tmp --mode full
	dh_install

override_dh_fixperms:
	dh_fixperms -Xusr/libexec/installed-tests
	chmod --recursive a+rX,u+w,og-w debian/libsdl2-tests/usr/libexec/installed-tests
