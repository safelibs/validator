  "rules": [
    {
      "pattern": "safe/sdl2main/src/lib.rs",
      "category": "ffi",
      "justification": "Exports the `SDL_main` compatibility shim consumed from C toolchains."
    },
    {
      "pattern": "safe/src/abi/generated_types.rs",
      "category": "generated",
      "justification": "Bindgen-generated foreign types, extern declarations, and layout assertions."
    },
    {
      "pattern": "safe/src/audio/*.rs",
      "category": "ffi",
      "justification": "Exported C ABI wrappers, raw audio buffers, and decoder/stream pointer interop."
    },
    {
      "pattern": "safe/src/core/*.rs",
      "category": "ffi",
      "justification": "Exported C ABI wrappers around libc, threading, allocation, logging, and platform runtime entrypoints."
    },
    {
      "pattern": "safe/src/events/*.rs",
      "category": "ffi",
      "justification": "Exported C ABI wrappers around event callbacks and raw SDL pointer types."
    },
    {
      "pattern": "safe/src/exports/generated_linux_stubs.rs",
      "category": "generated",
      "justification": "Generated aborting ABI stubs for unimplemented exports."
    },
    {
      "pattern": "safe/src/input/*.rs",
      "category": "ffi",
      "justification": "Exported C ABI wrappers over joystick/controller/haptic/sensor raw handles."
    },
    {
      "pattern": "safe/src/input/linux/*.rs",
      "category": "os",
      "justification": "Direct Linux device, evdev, udev, and ioctl interaction."
    },
    {
      "pattern": "safe/src/main_archive.rs",
      "category": "ffi",
      "justification": "Linker-visible archive helpers and exported C shims."
    },
    {
      "pattern": "safe/src/render/core.rs",
      "category": "ffi",
      "justification": "Renderer ABI surface and raw texture/renderer pointer ownership."
    },
    {
      "pattern": "safe/src/render/gl.rs",
      "category": "ffi",
      "justification": "Raw GL and Metal function-pointer forwarding across the SDL ABI."
    },
    {
      "pattern": "safe/src/render/gles.rs",
      "category": "performance",
      "justification": "Raw GLES proc-table access and texture upload kernels kept close to the ABI and hot paths."
    },
    {
      "pattern": "safe/src/render/local.rs",
      "category": "performance",
      "justification": "Local software renderer keeps raw SDL surface, texture, and window pointers in hot-path drawing code so the packaged fallback works without a host SDL runtime."
    },
    {
      "pattern": "safe/src/render/software.rs",
      "category": "ffi",
      "justification": "Raw renderer and surface pointer forwarding for the software backend."
    },
    {
      "pattern": "safe/src/testsupport/*.rs",
      "category": "ffi",
      "justification": "SDL_test support ports mirroring upstream pointer-heavy helpers."
    },
    {
      "pattern": "safe/src/video/*.rs",
      "category": "ffi",
      "justification": "Exported C ABI wrappers over windows, displays, surfaces, pixels, clipboard, and platform video handles."
    },
    {
      "pattern": "safe/src/video/linux/*.rs",
      "category": "os",
      "justification": "Direct Linux window-system, KMS/DRM, Wayland/X11, and IME integration."
    },
    {
      "pattern": "safe/tests/*.rs",
      "category": "tests",
      "justification": "Integration tests intentionally exercise ABI-level entrypoints, raw pointers, and external runtimes."
    },
    {
      "pattern": "safe/tests/common/*.rs",
      "category": "tests",
      "justification": "Shared ABI-level test harness helpers."
    },
    {
      "pattern": "safe/xtask/src/contracts.rs",
      "category": "generated",
      "justification": "Contract/codegen verification parses generated Rust and C signatures plus emitted unsafe export stubs."
    }
  ],
