[0.11111626890487969, "o", "no override packages found; continuing with apt originals\r\r\n"]
[0.1125868009403348, "o", "+ set -euo pipefail\r\r\n+ source /validator/tests/_shared/runtime_helpers.sh\r\r\n++ set -euo pipefail\r\r\n"]
[0.11268592090345919, "o", "++ mktemp -d\r\r\n"]
[0.1142977379495278, "o", "+ tmpdir=/tmp/validator-tmp\r\r\n+ trap 'rm -rf \"$tmpdir\"' EXIT\r\r\n+ python3 - /tmp/validator-tmp/in.ppm\r\r\n"]
[0.1218148049665615, "o", "+ cjpeg /tmp/validator-tmp/in.ppm\r\r\n"]
