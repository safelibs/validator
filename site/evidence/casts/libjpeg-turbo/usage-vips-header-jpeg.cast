[0.14411532995291054, "o", "/tmp/validator-tmp/in.jpg: 4x3 uchar, 3 bands, srgb, jpegload\r\r\n"]
[0.14485431101638824, "o", "+ validator_assert_contains /tmp/validator-tmp/out jpegload\r\r\n+ local path=/tmp/validator-tmp/out\r\r\n+ local needle=jpegload\r\r\n+ grep -Fq -- jpegload /tmp/validator-tmp/out\r\r\n"]
[0.14554980595130473, "o", "+ rm -rf /tmp/validator-tmp\r\r\n"]
