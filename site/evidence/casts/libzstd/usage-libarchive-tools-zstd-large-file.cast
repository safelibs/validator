[0.15306868799962103, "o", "./\r\r\n./payload.txt\r\r\n"]
[0.1533375090220943, "o", "+ bsdtar -xf /tmp/validator-tmp/a.tar.zstd -C /tmp/validator-tmp/out\r\r\n"]
[0.15552821406163275, "o", "+ validator_assert_contains /tmp/validator-tmp/out/payload.txt large-file\r\r\n+ local path=/tmp/validator-tmp/out/payload.txt\r\r\n+ local needle=large-file\r\r\n+ grep -Fq -- large-file /tmp/validator-tmp/out/payload.txt\r\r\n"]
[0.15594883705489337, "o", "+ rm -rf /tmp/validator-tmp\r\r\n"]
