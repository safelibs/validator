[0.10199657396879047, "o", "no override packages found; continuing with apt originals\r\r\n"]
[0.10374751698691398, "o", "+ set -euo pipefail\r\r\n+ source /validator/tests/_shared/runtime_helpers.sh\r\r\n++ set -euo pipefail\r\r\n"]
[0.10389932000543922, "o", "++ mktemp -d\r\r\n"]
[0.10524376505054533, "o", "+ tmpdir=/tmp/validator-tmp\r\r\n+ trap 'rm -rf \"$tmpdir\"' EXIT\r\r\n"]
