[0.1087237240280956, "o", "no override packages found; continuing with apt originals\r\r\n"]
[0.11074068699963391, "o", "+ set -euo pipefail\r\r\n+ source /validator/tests/_shared/runtime_helpers.sh\r\r\n++ set -euo pipefail\r\r\n++ mktemp -d\r\r\n"]
[0.1118737260112539, "o", "+ tmpdir=/tmp/validator-tmp\r\r\n+ trap 'rm -rf \"$tmpdir\"' EXIT\r\r\n+ mkdir -p /tmp/validator-tmp/in /tmp/validator-tmp/out\r\r\n"]
[0.11272700200788677, "o", "+ printf 'empty-dir\\n'\r\r\n"]
