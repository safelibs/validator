[0.12184823001734912, "o", "+ tee /tmp/validator-tmp/list\r\r\n"]
[0.12191102805081755, "o", "+ bsdtar -tf /tmp/validator-tmp/a.tar.zstd\r\r\n"]
[0.12334878405090421, "o", "./\r\r\n./payload.txt\r\r\n"]
[0.12350647896528244, "o", "+ bsdtar -xf /tmp/validator-tmp/a.tar.zstd -C /tmp/validator-tmp/out\r\r\n"]
[0.12526513705961406, "o", "+ validator_assert_contains /tmp/validator-tmp/out/payload.txt empty-dir\r\r\n+ local path=/tmp/validator-tmp/out/payload.txt\r\r\n+ local needle=empty-dir\r\r\n+ grep -Fq -- empty-dir /tmp/validator-tmp/out/payload.txt\r\r\n"]
[0.12622798304073513, "o", "+ rm -rf /tmp/validator-tmp\r\r\n"]
