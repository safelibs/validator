[0.11124191293492913, "o", "no override packages found; continuing with apt originals\r\r\n"]
[0.11275279789697379, "o", "+ set -euo pipefail\r\r\n+ source /validator/tests/_shared/runtime_helpers.sh\r\r\n"]
[0.11277497396804392, "o", "++ set -euo pipefail\r\r\n"]
[0.11299401696305722, "o", "++ mktemp -d\r\r\n"]
[0.11465630889870226, "o", "+ tmpdir=/tmp/validator-tmp\r\r\n"]
[0.1147000219207257, "o", "+ trap 'rm -rf \"$tmpdir\"' EXIT\r\r\n+ printf 'frame one\\n'\r\r\n+ printf 'frame two\\n'\r\r\n+ zstd -q -c /tmp/validator-tmp/one\r\r\n"]
[0.11609727994073182, "o", "+ zstd -q -c /tmp/validator-tmp/two\r\r\n"]
