[0.12826723093166947, "o", "+ zstd -q -dc /tmp/validator-tmp/both.zst\r\r\n+ tee /tmp/validator-tmp/out\r\r\n"]
[0.1286680808989331, "o", "frame one\r\r\nframe two\r\r\n"]
[0.12886467995122075, "o", "+ cmp /dev/fd/63 /tmp/validator-tmp/out\r\r\n"]
[0.12890209793113172, "o", "++ printf 'frame one\\nframe two\\n'\r\r\n"]
[0.1295109479688108, "o", "+ rm -rf /tmp/validator-tmp\r\r\n"]
