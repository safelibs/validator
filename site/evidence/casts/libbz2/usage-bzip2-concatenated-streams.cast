[0.11178239400032908, "o", "no override packages found; continuing with apt originals\r\r\n"]
[0.11319497099611908, "o", "+ set -euo pipefail\r\r\n+ source /validator/tests/_shared/runtime_helpers.sh\r\r\n++ set -euo pipefail\r\r\n++ mktemp -d\r\r\n"]
[0.11457047099247575, "o", "+ tmpdir=/tmp/validator-tmp\r\r\n+ trap 'rm -rf \"$tmpdir\"' EXIT\r\r\n+ printf 'one\\n'\r\r\n+ printf 'two\\n'\r\r\n+ bzip2 -c /tmp/validator-tmp/one\r\r\n"]
[0.11572962393984199, "o", "+ bzip2 -c /tmp/validator-tmp/two\r\r\n"]
