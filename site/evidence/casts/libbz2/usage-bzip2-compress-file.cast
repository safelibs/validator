[0.10077013494446874, "o", "no override packages found; continuing with apt originals\r\r\n"]
[0.10218909196555614, "o", "+ set -euo pipefail\r\r\n+ source /validator/tests/_shared/runtime_helpers.sh\r\r\n++ set -euo pipefail\r\r\n"]
[0.10223018401302397, "o", "++ mktemp -d\r\r\n"]
[0.10407532099634409, "o", "+ tmpdir=/tmp/validator-tmp\r\r\n+ trap 'rm -rf \"$tmpdir\"' EXIT\r\r\n+ printf 'alpha beta\\n'\r\r\n+ bzip2 -k /tmp/validator-tmp/in.txt\r\r\n"]
[0.10445853299461305, "o", "+ bzip2 -dc /tmp/validator-tmp/in.txt.bz2\r\r\n"]
[0.10449876799248159, "o", "+ tee /tmp/validator-tmp/out\r\r\n"]
[0.10513263393659145, "o", "alpha beta\r\r\n+ validator_assert_contains /tmp/validator-tmp/out 'alpha beta'\r\r\n+ local path=/tmp/validator-tmp/out\r\r\n+ local 'needle=alpha beta'\r\r\n+ grep -Fq -- 'alpha beta' /tmp/validator-tmp/out\r\r\n"]
[0.10595014097634703, "o", "+ rm -rf /tmp/validator-tmp\r\r\n"]
