[0.11063077102880925, "o", "no override packages found; continuing with apt originals\r\r\n"]
[0.11239307408686727, "o", "+ set -euo pipefail\r\r\n+ source /validator/tests/_shared/runtime_helpers.sh\r\r\n++ set -euo pipefail\r\r\n"]
[0.11264280905015767, "o", "++ mktemp -d\r\r\n"]
[0.11453161807730794, "o", "+ tmpdir=/tmp/validator-tmp\r\r\n+ trap 'rm -rf \"$tmpdir\"' EXIT\r\r\n+ python3 - /tmp/validator-tmp/in.ppm\r\r\n"]
