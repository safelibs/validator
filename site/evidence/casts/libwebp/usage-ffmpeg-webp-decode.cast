[0.12401532102376223, "o", "+ ffmpeg -hide_banner -loglevel error -i /tmp/validator-tmp/in.webp /tmp/validator-tmp/out.png\r\r\n"]
[0.16981790005229414, "o", "+ file /tmp/validator-tmp/out.png\r\r\n"]
[0.1704217940568924, "o", "/tmp/validator-tmp/out.png: PNG image data, 4 x 3, 8-bit/color RGB, non-interlaced\r\r\n"]
