[0.0976576249813661, "o", "no override packages found; continuing with apt originals\r\r\n"]
[0.09925259801093489, "o", "+ set -euo pipefail\r\r\n+ source /validator/tests/_shared/runtime_helpers.sh\r\r\n"]
[0.09935133904218674, "o", "++ set -euo pipefail\r\r\n"]
[0.09949702501762658, "o", "++ mktemp -d\r\r\n"]
[0.10080895700957626, "o", "+ tmpdir=/tmp/validator-tmp\r\r\n"]
[0.1009453929727897, "o", "+ trap 'rm -rf \"$tmpdir\"' EXIT\r\r\n+ python3 - /tmp/validator-tmp/in.ppm\r\r\n"]
