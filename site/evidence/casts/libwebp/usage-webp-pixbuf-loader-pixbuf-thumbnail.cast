[0.19406858400907367, "o", "no override packages found; continuing with apt originals\r\r\n"]
[0.1958172230515629, "o", "+ set -euo pipefail\r\r\n+ source /validator/tests/_shared/runtime_helpers.sh\r\r\n++ set -euo pipefail\r\r\n"]
