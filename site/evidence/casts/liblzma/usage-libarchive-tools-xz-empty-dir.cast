[0.12854915496427566, "o", "+ validator_assert_contains /tmp/validator-tmp/out/payload.txt empty-dir\r\r\n+ local path=/tmp/validator-tmp/out/payload.txt\r\r\n+ local needle=empty-dir\r\r\n"]
[0.12859945697709918, "o", "+ grep -Fq -- empty-dir /tmp/validator-tmp/out/payload.txt\r\r\n"]
[0.12905693298671395, "o", "+ rm -rf /tmp/validator-tmp\r\r\n"]
