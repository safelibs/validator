[0.10310924495570362, "o", "no override packages found; continuing with apt originals\r\r\n"]
[0.10465836990624666, "o", "+ set -euo pipefail\r\r\n+ source /validator/tests/_shared/runtime_helpers.sh\r\r\n++ set -euo pipefail\r\r\n"]
[0.10487327992450446, "o", "++ mktemp -d\r\r\n"]
[0.10590614494867623, "o", "+ tmpdir=/tmp/validator-tmp\r\r\n+ trap 'rm -rf \"$tmpdir\"' EXIT\r\r\n"]
