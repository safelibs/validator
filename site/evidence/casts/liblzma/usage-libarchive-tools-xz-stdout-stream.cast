[0.13025602302514017, "o", "no override packages found; continuing with apt originals\r\r\n"]
[0.13201019202824682, "o", "+ set -euo pipefail\r\r\n+ source /validator/tests/_shared/runtime_helpers.sh\r\r\n++ set -euo pipefail\r\r\n"]
[0.13205649005249143, "o", "++ mktemp -d\r\r\n"]
[0.13333189103286713, "o", "+ tmpdir=/tmp/validator-tmp\r\r\n+ trap 'rm -rf \"$tmpdir\"' EXIT\r\r\n+ mkdir -p /tmp/validator-tmp/in /tmp/validator-tmp/out\r\r\n"]
[0.1339438910363242, "o", "+ printf 'stdout-stream\\n'\r\r\n+ bsdtar -cJf /tmp/validator-tmp/a.tar.xz -C /tmp/validator-tmp/in .\r\r\n"]
