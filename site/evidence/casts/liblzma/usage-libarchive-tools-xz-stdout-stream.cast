[0.14317971002310514, "o", "./\r\r\n./payload.txt\r\r\n"]
[0.14343763305805624, "o", "+ bsdtar -xf /tmp/validator-tmp/a.tar.xz -C /tmp/validator-tmp/out\r\r\n"]
[0.14515886607114226, "o", "+ validator_assert_contains /tmp/validator-tmp/out/payload.txt stdout-stream\r\r\n+ local path=/tmp/validator-tmp/out/payload.txt\r\r\n+ local needle=stdout-stream\r\r\n+ grep -Fq -- stdout-stream /tmp/validator-tmp/out/payload.txt\r\r\n"]
[0.1456332680536434, "o", "+ rm -rf /tmp/validator-tmp\r\r\n"]
