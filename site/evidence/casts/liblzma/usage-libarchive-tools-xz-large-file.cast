[0.1188761560479179, "o", "./\r\r\n./payload.txt\r\r\n"]
[0.119145133998245, "o", "+ bsdtar -xf /tmp/validator-tmp/a.tar.xz -C /tmp/validator-tmp/out\r\r\n"]
[0.12089824303984642, "o", "+ validator_assert_contains /tmp/validator-tmp/out/payload.txt large-file\r\r\n+ local path=/tmp/validator-tmp/out/payload.txt\r\r\n+ local needle=large-file\r\r\n+ grep -Fq -- large-file /tmp/validator-tmp/out/payload.txt\r\r\n"]
[0.12147487001493573, "o", "+ rm -rf /tmp/validator-tmp\r\r\n"]
