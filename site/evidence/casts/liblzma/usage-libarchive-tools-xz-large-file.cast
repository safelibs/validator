[0.09878268896136433, "o", "no override packages found; continuing with apt originals\r\r\n"]
[0.10058191197458655, "o", "+ set -euo pipefail\r\r\n+ source /validator/tests/_shared/runtime_helpers.sh\r\r\n++ set -euo pipefail\r\r\n"]
[0.100730019970797, "o", "++ mktemp -d\r\r\n"]
[0.10191713797394186, "o", "+ tmpdir=/tmp/validator-tmp\r\r\n+ trap 'rm -rf \"$tmpdir\"' EXIT\r\r\n+ mkdir -p /tmp/validator-tmp/in /tmp/validator-tmp/out\r\r\n"]
