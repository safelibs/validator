[0.1056465080473572, "o", "no override packages found; continuing with apt originals\r\r\n"]
[0.10717998002655804, "o", "+ set -euo pipefail\r\r\n+ source /validator/tests/_shared/runtime_helpers.sh\r\r\n++ set -euo pipefail\r\r\n"]
[0.10730896599125117, "o", "++ mktemp -d\r\r\n"]
[0.10857895400840789, "o", "+ tmpdir=/tmp/validator-tmp\r\r\n+ trap 'rm -rf \"$tmpdir\"' EXIT\r\r\n+ mkdir -p /tmp/validator-tmp/in /tmp/validator-tmp/out\r\r\n"]
