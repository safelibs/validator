[0.11039201100356877, "o", "no override packages found; continuing with apt originals\r\r\n"]
[0.1120281390612945, "o", "+ set -euo pipefail\r\r\n+ source /validator/tests/_shared/runtime_helpers.sh\r\r\n++ set -euo pipefail\r\r\n"]
[0.11218837404157966, "o", "++ mktemp -d\r\r\n"]
[0.11362478509545326, "o", "+ tmpdir=/tmp/validator-tmp\r\r\n+ trap 'rm -rf \"$tmpdir\"' EXIT\r\r\n+ validator_make_fixture /tmp/validator-tmp/in.xml '<root><item name=\"alpha\">1</item><item name=\"beta\">2</item></root>'\r\r\n"]
[0.11368785402737558, "o", "+ local path=/tmp/validator-tmp/in.xml\r\r\n"]
[0.11379976407624781, "o", "++ dirname /tmp/validator-tmp/in.xml\r\r\n"]
[0.11416818900033832, "o", "+ mkdir -p /tmp/validator-tmp\r\r\n"]
[0.11535457603167742, "o", "+ (( 2 > 1 ))\r\r\n+ printf %s '<root><item name=\"alpha\">1</item><item name=\"beta\">2</item></root>'\r\r\n+ xmlstarlet val -w /tmp/validator-tmp/in.xml\r\r\n+ tee /tmp/validator-tmp/out\r\r\n"]
[0.11668989609461278, "o", "/tmp/validator-tmp/in.xml - valid\r\r\n"]
[0.11689179809764028, "o", "+ validator_assert_contains /tmp/validator-tmp/out valid\r\r\n+ local path=/tmp/validator-tmp/out\r\r\n"]
[0.11690717202145606, "o", "+ local needle=valid\r\r\n+ grep -Fq -- valid /tmp/validator-tmp/out\r\r\n"]
[0.11752475402317941, "o", "+ rm -rf /tmp/validator-tmp\r\r\n"]
