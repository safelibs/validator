[0.11672078899573535, "o", "no override packages found; continuing with apt originals\r\r\n"]
[0.11862844601273537, "o", "+ set -euo pipefail\r\r\n+ source /validator/tests/_shared/runtime_helpers.sh\r\r\n++ set -euo pipefail\r\r\n++ mktemp -d\r\r\n"]
[0.12018949398770928, "o", "+ tmpdir=/tmp/validator-tmp\r\r\n+ trap 'rm -rf \"$tmpdir\"' EXIT\r\r\n+ printf '<!ELEMENT root EMPTY>\\n'\r\r\n+ cat\r\r\n"]
[0.12129865307360888, "o", "+ xmlcatalog /tmp/validator-tmp/catalog.xml '-//Example//DTD Demo//EN'\r\r\n+ tee /tmp/validator-tmp/lookup\r\r\n"]
[0.12269960006233305, "o", "/tmp/validator-tmp/demo.dtd\r\r\n+ grep demo.dtd /tmp/validator-tmp/lookup\r\r\n"]
[0.12329930800478905, "o", "/tmp/validator-tmp/demo.dtd\r\r\n+ rm -rf /tmp/validator-tmp\r\r\n"]
