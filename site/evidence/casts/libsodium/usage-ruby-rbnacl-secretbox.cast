[0.10189034591894597, "o", "no override packages found; continuing with apt originals\r\r\n"]
[0.10355059592984617, "o", "+ set -euo pipefail\r\r\n+ source /validator/tests/_shared/runtime_helpers.sh\r\r\n++ set -euo pipefail\r\r\n"]
[0.10396730690263212, "o", "++ mktemp -d\r\r\n"]
[0.10493447096087039, "o", "+ tmpdir=/tmp/validator-tmp\r\r\n+ trap 'rm -rf \"$tmpdir\"' EXIT\r\r\n+ ruby -rrbnacl -e 'key=RbNaCl::Random.random_bytes(RbNaCl::SecretBox.key_bytes); box=RbNaCl::SecretBox.new(key); nonce=RbNaCl::Random.random_bytes(box.nonce_bytes); cipher=box.encrypt(nonce, \"payload\"); puts box.decrypt(nonce, cipher)'\r\r\n"]
[0.15154235600493848, "o", "payload\r\r\n"]
[0.15285246190614998, "o", "+ rm -rf /tmp/validator-tmp\r\r\n"]
