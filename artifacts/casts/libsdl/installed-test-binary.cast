[0.10728940204717219, "o", "+ tmpdir=/tmp/validator-tmp\r\r\n"]
[0.10733961104415357, "o", "+ trap 'rm -rf \"$tmpdir\"' EXIT\r\r\n+ export SDL_AUDIODRIVER=dummy SDL_VIDEODRIVER=dummy HOME=/tmp/validator-tmp\r\r\n+ SDL_AUDIODRIVER=dummy\r\r\n+ SDL_VIDEODRIVER=dummy\r\r\n+ HOME=/tmp/validator-tmp\r\r\n+ for c in /usr/libexec/installed-tests/SDL2/testplatform /usr/libexec/installed-tests/SDL2/testtimer\r\r\n+ [[ -x /usr/libexec/installed-tests/SDL2/testplatform ]]\r\r\n"]
[0.10769404610618949, "o", "+ /usr/libexec/installed-tests/SDL2/testplatform\r\r\n+ tee /tmp/validator-tmp/out\r\r\n"]
