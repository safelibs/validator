{"version": 2, "width": 120, "height": 40, "timestamp": 0, "env": {"TERM": "xterm-256color", "SHELL": "/bin/bash"}}
[0.11868907301686704, "o", "no override packages found; continuing with apt originals\r\r\n"]
[0.1198856079718098, "o", "+ set -euo pipefail\r\r\n+ source /validator/tests/_shared/runtime_helpers.sh\r\r\n++ set -euo pipefail\r\r\n"]
[0.12022608402185142, "o", "++ mktemp -d\r\r\n"]
[0.12171113200020045, "o", "+ tmpdir=/tmp/validator-tmp\r\r\n+ trap 'rm -rf \"$tmpdir\"' EXIT\r\r\n+ port=17681\r\r\n+ pid=11\r\r\n+ trap 'kill \"$pid\" 2>/dev/null || true; rm -rf \"$tmpdir\"' EXIT\r\r\n+ ttyd -i 127.0.0.1 -p 17681 bash -lc 'printf validator-ttyd'\r\r\n++ seq 1 40\r\r\n"]
[0.12219681299757212, "o", "+ for _ in $(seq 1 40)\r\r\n+ curl -fsS http://127.0.0.1:17681/\r\r\n"]
[0.12854608905036002, "o", "+ break\r\r\n+ validator_require_file /tmp/validator-tmp/page.html\r\r\n+ local path=/tmp/validator-tmp/page.html\r\r\n+ [[ -f /tmp/validator-tmp/page.html ]]\r\r\n+ validator_assert_contains /tmp/validator-tmp/page.html ttyd\r\r\n+ local path=/tmp/validator-tmp/page.html\r\r\n+ local needle=ttyd\r\r\n+ grep -Fq -- ttyd /tmp/validator-tmp/page.html\r\r\n"]
[0.14806617004796863, "o", "+ kill 11\r\r\n+ wait 11\r\r\n"]
[0.14856820402201265, "o", "+ kill 11\r\r\n+ true\r\r\n+ rm -rf /tmp/validator-tmp\r\r\n"]
