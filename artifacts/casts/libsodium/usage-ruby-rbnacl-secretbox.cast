[0.1071248579537496, "o", "no override packages found; continuing with apt originals\r\r\n"]
[0.10881483892444521, "o", "+ set -euo pipefail\r\r\n+ source /validator/tests/_shared/runtime_helpers.sh\r\r\n++ set -euo pipefail\r\r\n"]
[0.10902390093542635, "o", "++ mktemp -d\r\r\n"]
[0.11032266798429191, "o", "+ tmpdir=/tmp/validator-tmp\r\r\n+ trap 'rm -rf \"$tmpdir\"' EXIT\r\r\n+ ruby -rrbnacl -e 'key=RbNaCl::Random.random_bytes(RbNaCl::SecretBox.key_bytes); box=RbNaCl::SecretBox.new(key); nonce=RbNaCl::Random.random_bytes(box.nonce_bytes); cipher=box.encrypt(nonce, \"payload\"); puts box.decrypt(nonce, cipher)'\r\r\n"]
[0.15840976999606937, "o", "payload\r\r\n"]
[0.16011380893178284, "o", "+ rm -rf /tmp/validator-tmp\r\r\n"]
