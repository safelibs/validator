[0.10892317199613899, "o", "no override packages found; continuing with apt originals\r\r\n"]
[0.11042097792960703, "o", "+ set -euo pipefail\r\r\n+ source /validator/tests/_shared/runtime_helpers.sh\r\r\n++ set -euo pipefail\r\r\n"]
[0.11056621302850544, "o", "++ mktemp -d\r\r\n"]
[0.11207859497517347, "o", "+ tmpdir=/tmp/validator-tmp\r\r\n+ trap 'rm -rf \"$tmpdir\"' EXIT\r\r\n+ printf '<!ELEMENT root EMPTY>\\n'\r\r\n+ cat\r\r\n"]
