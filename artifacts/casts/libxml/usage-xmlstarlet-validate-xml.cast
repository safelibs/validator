[0.10805348108988255, "o", "no override packages found; continuing with apt originals\r\r\n"]
[0.10993358807172626, "o", "+ set -euo pipefail\r\r\n+ source /validator/tests/_shared/runtime_helpers.sh\r\r\n++ set -euo pipefail\r\r\n"]
[0.1100225429981947, "o", "++ mktemp -d\r\r\n"]
[0.11128979502245784, "o", "+ tmpdir=/tmp/validator-tmp\r\r\n+ trap 'rm -rf \"$tmpdir\"' EXIT\r\r\n+ validator_make_fixture /tmp/validator-tmp/in.xml '<root><item name=\"alpha\">1</item><item name=\"beta\">2</item></root>'\r\r\n+ local path=/tmp/validator-tmp/in.xml\r\r\n"]
[0.11150083306711167, "o", "++ dirname /tmp/validator-tmp/in.xml\r\r\n"]
[0.11184278700966388, "o", "+ mkdir -p /tmp/validator-tmp\r\r\n"]
[0.11240077600814402, "o", "+ (( 2 > 1 ))\r\r\n+ printf %s '<root><item name=\"alpha\">1</item><item name=\"beta\">2</item></root>'\r\r\n"]
[0.11288425303064287, "o", "+ xmlstarlet val -w /tmp/validator-tmp/in.xml\r\r\n+ tee /tmp/validator-tmp/out\r\r\n"]
[0.11493530205916613, "o", "/tmp/validator-tmp/in.xml - valid\r\r\n+ validator_assert_contains /tmp/validator-tmp/out valid\r\r\n+ local path=/tmp/validator-tmp/out\r\r\n+ local needle=valid\r\r\n+ grep -Fq -- valid /tmp/validator-tmp/out\r\r\n"]
[0.11523054807912558, "o", "+ rm -rf /tmp/validator-tmp\r\r\n"]
