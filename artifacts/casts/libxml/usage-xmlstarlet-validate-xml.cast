[0.11698258190881461, "o", "no override packages found; continuing with apt originals\r\r\n"]
[0.11828355002216995, "o", "+ set -euo pipefail\r\r\n+ source /validator/tests/_shared/runtime_helpers.sh\r\r\n++ set -euo pipefail\r\r\n"]
[0.11857549997512251, "o", "++ mktemp -d\r\r\n"]
[0.11965886491816491, "o", "+ tmpdir=/tmp/validator-tmp\r\r\n+ trap 'rm -rf \"$tmpdir\"' EXIT\r\r\n"]
[0.11968641192652285, "o", "+ validator_make_fixture /tmp/validator-tmp/in.xml '<root><item name=\"alpha\">1</item><item name=\"beta\">2</item></root>'\r\r\n+ local path=/tmp/validator-tmp/in.xml\r\r\n"]
[0.12002416397444904, "o", "++ dirname /tmp/validator-tmp/in.xml\r\r\n"]
[0.120371630997397, "o", "+ mkdir -p /tmp/validator-tmp\r\r\n"]
[0.12117450300138444, "o", "+ (( 2 > 1 ))\r\r\n+ printf %s '<root><item name=\"alpha\">1</item><item name=\"beta\">2</item></root>'\r\r\n"]
[0.1214383589103818, "o", "+ xmlstarlet val -w /tmp/validator-tmp/in.xml\r\r\n+ tee /tmp/validator-tmp/out\r\r\n"]
[0.12288231600541621, "o", "/tmp/validator-tmp/in.xml - valid\r\r\n"]
[0.12317685596644878, "o", "+ validator_assert_contains /tmp/validator-tmp/out valid\r\r\n+ local path=/tmp/validator-tmp/out\r\r\n+ local needle=valid\r\r\n+ grep -Fq -- valid /tmp/validator-tmp/out\r\r\n"]
[0.12393575697205961, "o", "+ rm -rf /tmp/validator-tmp\r\r\n"]
