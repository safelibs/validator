[0.1936513800173998, "o", "no override packages found; continuing with apt originals\r\r\n"]
[0.19536306301597506, "o", "+ set -euo pipefail\r\r\n+ source /validator/tests/_shared/runtime_helpers.sh\r\r\n++ set -euo pipefail\r\r\n++ mktemp -d\r\r\n"]
[0.1995882139308378, "o", "+ tmpdir=/tmp/validator-tmp\r\r\n+ trap 'rm -rf \"$tmpdir\"' EXIT\r\r\n+ validator_make_fixture /tmp/validator-tmp/in.xml '<root><item name=\"alpha\">1</item><item name=\"beta\">2</item></root>'\r\r\n+ local path=/tmp/validator-tmp/in.xml\r\r\n"]
[0.19974089099559933, "o", "++ dirname /tmp/validator-tmp/in.xml\r\r\n"]
[0.19996461202390492, "o", "+ mkdir -p /tmp/validator-tmp\r\r\n"]
[0.20061053393874317, "o", "+ (( 2 > 1 ))\r\r\n+ printf %s '<root><item name=\"alpha\">1</item><item name=\"beta\">2</item></root>'\r\r\n"]
[0.2008248360361904, "o", "+ xmlstarlet val -w /tmp/validator-tmp/in.xml\r\r\n"]
[0.2009246009401977, "o", "+ tee /tmp/validator-tmp/out\r\r\n"]
[0.20238451298791915, "o", "/tmp/validator-tmp/in.xml - valid\r\r\n"]
[0.2027008259901777, "o", "+ validator_assert_contains /tmp/validator-tmp/out valid\r\r\n+ local path=/tmp/validator-tmp/out\r\r\n+ local needle=valid\r\r\n+ grep -Fq -- valid /tmp/validator-tmp/out\r\r\n"]
[0.20314447896089405, "o", "+ rm -rf /tmp/validator-tmp\r\r\n"]
