[0.11920641001779586, "o", "no override packages found; continuing with apt originals\r\r\n"]
[0.12082593503873795, "o", "+ set -euo pipefail\r\r\n+ source /validator/tests/_shared/runtime_helpers.sh\r\r\n++ set -euo pipefail\r\r\n"]
[0.12090962799265981, "o", "++ mktemp -d\r\r\n"]
[0.12259217002429068, "o", "+ tmpdir=/tmp/validator-tmp\r\r\n"]
[0.12285020400304347, "o", "+ trap 'rm -rf \"$tmpdir\"' EXIT\r\r\n+ printf '<root><item id=\"1\">alpha</item></root>\\n'\r\r\n+ xmllint --noout /tmp/validator-tmp/in.xml\r\r\n"]
[0.12466891400981694, "o", "+ xmllint --format /tmp/validator-tmp/in.xml\r\r\n+ tee /tmp/validator-tmp/f.xml\r\r\n"]
[0.12602518300991505, "o", "<?xml version=\"1.0\"?>\r\r\n<root>\r\r\n  <item id=\"1\">alpha</item>\r\r\n</root>\r\r\n+ grep '<item id=\"1\">alpha</item>' /tmp/validator-tmp/f.xml\r\r\n"]
[0.12679131503682584, "o", "  <item id=\"1\">alpha</item>\r\r\n+ rm -rf /tmp/validator-tmp\r\r\n"]
