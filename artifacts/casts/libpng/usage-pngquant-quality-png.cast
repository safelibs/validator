[0.11786765593569726, "o", "+ validator_require_file /tmp/validator-tmp/out.png\r\r\n+ local path=/tmp/validator-tmp/out.png\r\r\n+ [[ -f /tmp/validator-tmp/out.png ]]\r\r\n+ rm -rf /tmp/validator-tmp\r\r\n"]
