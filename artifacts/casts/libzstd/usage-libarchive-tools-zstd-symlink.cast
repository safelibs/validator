[0.11600424803327769, "o", "+ tee /tmp/validator-tmp/list\r\r\n"]
[0.11730315303429961, "o", "./\r\r\n./payload.txt"]
[0.11732563201803714, "o", "\r\r\n"]
[0.1174809520598501, "o", "+ bsdtar -xf /tmp/validator-tmp/a.tar.zstd -C /tmp/validator-tmp/out\r\r\n"]
[0.11918488296214491, "o", "+ validator_assert_contains /tmp/validator-tmp/out/payload.txt symlink\r\r\n+ local path=/tmp/validator-tmp/out/payload.txt\r\r\n+ local needle=symlink\r\r\n"]
[0.1192121299682185, "o", "+ grep -Fq -- symlink /tmp/validator-tmp/out/payload.txt\r\r\n"]
