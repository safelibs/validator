[0.1255977989640087, "o", "./\r\r\n./payload.txt\r\r\n"]
[0.12584164703730494, "o", "+ bsdtar -xf /tmp/validator-tmp/a.tar.zstd -C /tmp/validator-tmp/out\r\r\n"]
[0.127768637961708, "o", "+ validator_assert_contains /tmp/validator-tmp/out/payload.txt large-file\r\r\n+ local path=/tmp/validator-tmp/out/payload.txt\r\r\n+ local needle=large-file\r\r\n+ grep -Fq -- large-file /tmp/validator-tmp/out/payload.txt\r\r\n"]
[0.12832958600483835, "o", "+ rm -rf /tmp/validator-tmp\r\r\n"]
