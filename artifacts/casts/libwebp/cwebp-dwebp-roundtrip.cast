[0.11538930900860578, "o", "no override packages found; continuing with apt originals\r\r\n"]
[0.11723957909271121, "o", "+ set -euo pipefail\r\r\n+ source /validator/tests/_shared/runtime_helpers.sh\r\r\n++ set -euo pipefail\r\r\n++ mktemp -d\r\r\n"]
[0.11858941207174212, "o", "+ tmpdir=/tmp/validator-tmp\r\r\n+ trap 'rm -rf \"$tmpdir\"' EXIT\r\r\n+ python3 - /tmp/validator-tmp/in.ppm\r\r\n"]
[0.12794129201211035, "o", "+ cwebp -quiet /tmp/validator-tmp/in.ppm -o /tmp/validator-tmp/a.webp\r\r\n"]
[0.12983958807308227, "o", "+ dwebp /tmp/validator-tmp/a.webp -ppm -o /tmp/validator-tmp/out.ppm\r\r\n"]
[0.13022106303833425, "o", "Decoded /tmp/validator-tmp/a.webp. Dimensions: 2 x 2 . Format: lossy. Now saving...\r\r\nSaved file /tmp/validator-tmp/out.ppm\r\r\n+ head -n 3 /tmp/validator-tmp/out.ppm\r\r\n"]
[0.13057050108909607, "o", "P6\r\r\n2 2\r\r\n255\r\r\n+ rm -rf /tmp/validator-tmp\r\r\n"]
