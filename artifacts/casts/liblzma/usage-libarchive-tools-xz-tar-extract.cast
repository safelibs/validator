[0.18885949393734336, "o", "no override packages found; continuing with apt originals\r\r\n"]
[0.19078793795779347, "o", "+ set -euo pipefail\r\r\n+ source /validator/tests/_shared/runtime_helpers.sh\r\r\n++ set -euo pipefail\r\r\n"]
[0.19082600600086153, "o", "++ mktemp -d\r\r\n"]
[0.19498509203549474, "o", "+ tmpdir=/tmp/validator-tmp\r\r\n+ trap 'rm -rf \"$tmpdir\"' EXIT\r\r\n+ mkdir -p /tmp/validator-tmp/in /tmp/validator-tmp/out\r\r\n"]
[0.19563439500052482, "o", "+ printf 'tar-extract\\n'\r\r\n+ bsdtar -cJf /tmp/validator-tmp/a.tar.xz -C /tmp/validator-tmp/in .\r\r\n"]
