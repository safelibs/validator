[0.11501225701067597, "o", "+ bsdtar -xf /tmp/validator-tmp/a.tar.xz -C /tmp/validator-tmp/out\r\r\n"]
[0.11670487106312066, "o", "+ validator_assert_contains /tmp/validator-tmp/out/payload.txt symlink\r\r\n+ local path=/tmp/validator-tmp/out/payload.txt\r\r\n+ local needle=symlink\r\r\n"]
[0.11672991001978517, "o", "+ grep -Fq -- symlink /tmp/validator-tmp/out/payload.txt\r\r\n"]
