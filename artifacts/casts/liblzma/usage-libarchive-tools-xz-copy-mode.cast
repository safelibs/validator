[0.11186406598426402, "o", "no override packages found; continuing with apt originals\r\r\n"]
[0.11399865499697626, "o", "+ set -euo pipefail\r\r\n+ source /validator/tests/_shared/runtime_helpers.sh\r\r\n++ set -euo pipefail\r\r\n"]
[0.11426349496468902, "o", "++ mktemp -d\r\r\n"]
[0.11633372795768082, "o", "+ tmpdir=/tmp/validator-tmp\r\r\n+ trap 'rm -rf \"$tmpdir\"' EXIT\r\r\n+ mkdir -p /tmp/validator-tmp/in /tmp/validator-tmp/out\r\r\n"]
[0.1163981530116871, "o", "+ printf 'copy-mode\\n'\r\r\n"]
