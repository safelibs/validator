[0.12465853802859783, "o", "+ bsdtar -tf /tmp/validator-tmp/a.tar.xz\r\r\n"]
[0.12476659496314824, "o", "+ tee /tmp/validator-tmp/list\r\r\n"]
[0.12605621002148837, "o", "./\r\r\n./payload.txt\r\r\n"]
[0.12609624594915658, "o", "+ bsdtar -xf /tmp/validator-tmp/a.tar.xz -C /tmp/validator-tmp/out\r\r\n"]
[0.1279632089426741, "o", "+ validator_assert_contains /tmp/validator-tmp/out/payload.txt copy-mode\r\r\n+ local path=/tmp/validator-tmp/out/payload.txt\r\r\n+ local needle=copy-mode\r\r\n+ grep -Fq -- copy-mode /tmp/validator-tmp/out/payload.txt\r\r\n"]
[0.1283905029995367, "o", "+ rm -rf /tmp/validator-tmp\r\r\n"]
