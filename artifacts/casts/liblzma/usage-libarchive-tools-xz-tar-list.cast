[0.10377738007809967, "o", "no override packages found; continuing with apt originals\r\r\n"]
[0.10514696897007525, "o", "+ set -euo pipefail\r\r\n+ source /validator/tests/_shared/runtime_helpers.sh\r\r\n++ set -euo pipefail\r\r\n"]
[0.10540140199009329, "o", "++ mktemp -d\r\r\n"]
[0.10655530705116689, "o", "+ tmpdir=/tmp/validator-tmp\r\r\n+ trap 'rm -rf \"$tmpdir\"' EXIT\r\r\n+ mkdir -p /tmp/validator-tmp/in /tmp/validator-tmp/out\r\r\n"]
