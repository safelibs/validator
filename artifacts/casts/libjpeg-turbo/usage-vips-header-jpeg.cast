[0.1368456679629162, "o", "+ validator_assert_contains /tmp/validator-tmp/out jpegload\r\r\n+ local path=/tmp/validator-tmp/out\r\r\n+ local needle=jpegload\r\r\n+ grep -Fq -- jpegload /tmp/validator-tmp/out\r\r\n"]
[0.13763422099873424, "o", "+ rm -rf /tmp/validator-tmp\r\r\n"]
