[0.11122992704622447, "o", "no override packages found; continuing with apt originals\r\r\n"]
[0.11330061301123351, "o", "+ set -euo pipefail\r\r\n+ source /validator/tests/_shared/runtime_helpers.sh\r\r\n++ set -euo pipefail\r\r\n"]
[0.11371090810280293, "o", "++ mktemp -d\r\r\n"]
[0.11553548206575215, "o", "+ tmpdir=/tmp/validator-tmp\r\r\n+ trap 'rm -rf \"$tmpdir\"' EXIT\r\r\n+ printf 'alpha beta\\n'\r\r\n+ bzip2 -k /tmp/validator-tmp/in.txt\r\r\n"]
[0.11629644606728107, "o", "+ bzip2 -dc /tmp/validator-tmp/in.txt.bz2\r\r\n+ tee /tmp/validator-tmp/out\r\r\n"]
[0.11694675404578447, "o", "alpha beta\r\r\n+ validator_assert_contains /tmp/validator-tmp/out 'alpha beta'\r\r\n+ local path=/tmp/validator-tmp/out\r\r\n+ local 'needle=alpha beta'\r\r\n+ grep -Fq -- 'alpha beta' /tmp/validator-tmp/out\r\r\n"]
[0.11761794704943895, "o", "+ rm -rf /tmp/validator-tmp\r\r\n"]
