[0.10290072998031974, "o", "no override packages found; continuing with apt originals\r\r\n"]
[0.10470927401911467, "o", "+ set -euo pipefail\r\r\n+ source /validator/tests/_shared/runtime_helpers.sh\r\r\n++ set -euo pipefail\r\r\n++ mktemp -d\r\r\n"]
[0.10584267601370811, "o", "+ tmpdir=/tmp/validator-tmp\r\r\n+ trap 'rm -rf \"$tmpdir\"' EXIT\r\r\n+ printf 'alpha beta\\n'\r\r\n+ bzip2 -k /tmp/validator-tmp/in.txt\r\r\n"]
[0.10663396306335926, "o", "+ bzip2 -dc /tmp/validator-tmp/in.txt.bz2\r\r\n+ tee /tmp/validator-tmp/out\r\r\n"]
[0.1069245170801878, "o", "alpha beta\r\r\n+ validator_assert_contains /tmp/validator-tmp/out 'alpha beta'\r\r\n+ local path=/tmp/validator-tmp/out\r\r\n+ local 'needle=alpha beta'\r\r\n+ grep -Fq -- 'alpha beta' /tmp/validator-tmp/out\r\r\n"]
[0.1075447240145877, "o", "+ rm -rf /tmp/validator-tmp\r\r\n"]
