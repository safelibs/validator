[0.11756554304156452, "o", "+ validator_assert_contains /tmp/validator-tmp/out two\r\r\n"]
[0.11758560605812818, "o", "+ local path=/tmp/validator-tmp/out\r\r\n+ local needle=two\r\r\n+ grep -Fq -- two /tmp/validator-tmp/out\r\r\n"]
[0.11815633799415082, "o", "+ rm -rf /tmp/validator-tmp\r\r\n"]
