[0.10983446892350912, "o", "+ validator_assert_contains /tmp/validator-tmp/out two\r\r\n+ local path=/tmp/validator-tmp/out\r\r\n+ local needle=two\r\r\n"]
[0.10985051991883665, "o", "+ grep -Fq -- two /tmp/validator-tmp/out\r\r\n"]
[0.1103607079712674, "o", "+ rm -rf /tmp/validator-tmp\r\r\n"]
