[0.054, "o", "Unknown option --format\n"]
[0.055, "o", "Usage : xmllint [options] XMLfiles ...\n"]
[0.056, "o", "\tParse the XML files and output the result of the parsing\n"]
[0.057, "o", "\t--version : display the version of the XML library used\n"]
[0.058, "o", "\t--debug : dump a debug tree of the in-memory document\n"]
[0.059, "o", "\t--shell : run a navigating shell\n"]
[0.06, "o", "\t--noout : don't output the result tree\n"]
[0.061, "o", "\t--valid : validate the document in addition to std well-formed check\n"]
[0.062, "o", "\t--schema schema : do validation against the WXS schema\n"]
[0.063, "o", "\t--relaxng schema : do RelaxNG validation against the schema\n"]
[0.064, "o", "\t--schematron schema : do validation against a schematron\n"]
[0.065, "o", "\t--timing : print some timings\n"]
[0.066, "o", "\t--output file or -o file: save to a given file\n"]
[0.067, "o", "\t--repeat : repeat 100 times, for timing or profiling\n"]
[0.068, "o", "\t--memory : parse from memory\n"]
[0.069, "o", "\t--nowarning : do not emit warnings from parser/validator\n"]
[0.07, "o", "\t--xinclude : do XInclude processing\n"]
[0.071, "o", "\t--noxincludenode : same but do not generate XInclude nodes\n"]
[0.072, "o", "\t--stream : use the streaming interface to process very large files\n"]
[0.073, "o", "\t--walker : create a reader and walk though the resulting doc\n"]
[0.074, "o", "\t--push : use the push mode of the parser\n"]
[0.075, "o", "\t--pushsmall : use the push mode of the parser using tiny increments\n"]
[0.076, "o", "\t--pattern pattern_value : test the pattern support\n"]
[0.077, "o", "\t--nonet : refuse to fetch DTDs or entities over network\n"]
[0.078, "o", "\t--noent : substitute entity references by their value\n"]
[0.079, "o", "\t--oldxml10: use XML-1.0 parsing rules before the 5th edition\n"]
